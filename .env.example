# App runtime
NODE_ENV=production
PORT=3000

# Internet deployment (Render)
# Keep SQLite in /data (mounted persistent disk in render.yaml)
# No DATABASE_URL needed for this low-cost setup.

# Razorpay (optional for online UPI/Card)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Swiggy integration (optional, official partner credentials required)
SWIGGY_ENABLED=false
SWIGGY_API_BASE_URL=
SWIGGY_API_TOKEN=
SWIGGY_WEBHOOK_SECRET=
SWIGGY_STORE_ID=
SWIGGY_WEBHOOK_STRICT=true
SWIGGY_SYNC_INTERVAL_MS=15000
SWIGGY_ONLY_MODE=false
SWIGGY_MENU_PULL_ENABLED=false
SWIGGY_MENU_PULL_INTERVAL_MS=300000

# Basic API rate limiting (in-memory)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=240

# Local SQLite backup settings
DB_BACKUP_ENABLED=true
DB_BACKUP_INTERVAL_MINUTES=60
DB_BACKUP_RETENTION_COUNT=48
