# App runtime
NODE_ENV=production
PORT=3000

# Internet deployment (Render)
# Keep SQLite in /data (mounted persistent disk in render.yaml)
# No DATABASE_URL needed for this low-cost setup.

# Razorpay (optional for online UPI/Card)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Basic API rate limiting (in-memory)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=240

# Local SQLite backup settings
DB_BACKUP_ENABLED=true
DB_BACKUP_INTERVAL_MINUTES=60
DB_BACKUP_RETENTION_COUNT=48
# Optional explicit DB locations (recommended for cloud deployments)
# DATA_DIR=/opt/render/project/src/data
# DB_FILE=/opt/render/project/src/data/restaurant.db
# DB_BACKUP_DIR=/opt/render/project/src/data/backups
# Safety switch: fail startup in production if DB file is missing
REQUIRE_PERSISTENT_DB=true

# Management authentication
# Used to sign login tokens (set a long random value in production)
MANAGEMENT_AUTH_SECRET=
# Optional one-time default password for the default restaurant account
MANAGEMENT_DEFAULT_PASSWORD=
# Fallback used when no auth row exists and MANAGEMENT_DEFAULT_PASSWORD is empty
MANAGEMENT_DEV_FALLBACK_PASSWORD=admin123
# Required to add/update restaurant management passwords after first bootstrap account
MANAGEMENT_SETUP_KEY=

# Supabase migration helpers (one-time migration script)
# Use pooled connection string from Supabase: Settings -> Database -> Connection string (URI)
DATABASE_URL=
# Set true when your Postgres URL requires SSL (Supabase usually does)
PGSSL=true
# Optional source SQLite file path for migration script
# SQLITE_FILE=./data/restaurant.db
