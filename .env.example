# App runtime
NODE_ENV=production
PORT=3000

# Internet deployment (Render)
# Keep SQLite in /data (mounted persistent disk in render.yaml)
# No DATABASE_URL needed for this low-cost setup.

# Razorpay (optional for online UPI/Card)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Basic API rate limiting (in-memory)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=240

# Local SQLite backup settings
DB_BACKUP_ENABLED=true
DB_BACKUP_INTERVAL_MINUTES=60
DB_BACKUP_RETENTION_COUNT=48

# Management authentication
# Used to sign login tokens (set a long random value in production)
MANAGEMENT_AUTH_SECRET=
# Optional one-time default password for the default restaurant account
MANAGEMENT_DEFAULT_PASSWORD=
# Development-only fallback when no auth row exists (ignored in production)
MANAGEMENT_DEV_FALLBACK_PASSWORD=admin123
# Required to add/update restaurant management passwords after first bootstrap account
MANAGEMENT_SETUP_KEY=
